# Shopify App Credentials (from shopify.app.toml / Partners dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Connected Shops (JSON: domain → access token)
# Add stores by installing the app, then adding the token here
SHOPS={"nailstuff-dev.myshopify.com":"shpat_xxx","nailstuff-ca.myshopify.com":"shpat_yyy"}

# Legacy single-shop (still works as fallback)
# SHOP_DOMAIN=your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=

# MCP Server Auth (Bearer token for direct MCP clients like Claude Code)
MCP_AUTH_TOKEN=

# OAuth 2.0 (for ChatGPT and other MCP clients that require OAuth)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Shopify API Version
SHOPIFY_API_VERSION=2026-07

# Server
PORT=3000
HOST_URL=https://ns-mcp-325z.onrender.com
