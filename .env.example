# Shopify App Credentials (from shopify.app.toml / Partners dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Store-specific (set after OAuth install)
SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# MCP Server
MCP_AUTH_TOKEN=your-secret-token-for-mcp-clients
PORT=3000

# Shopify API Version
SHOPIFY_API_VERSION=2026-07
